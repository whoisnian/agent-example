# Alibaba DashScope API key — required for ChatTongyi / DeepSeek-V3.2
# Get yours at https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: output path for the generated HTML report (default: report.html)
# REPORT_OUTPUT_PATH=report.html

# Optional: enable LangSmith tracing for better observability (default: false)
# Get your API key and project name at https://smith.langchain.com/
# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=lsv2_pt_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx_xxxxxxxxxx
# LANGSMITH_PROJECT="agent-example"
